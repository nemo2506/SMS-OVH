# .gitignore — généré pour MS-OVH-SMS

# Android/Gradle
.idea/
*.iml
local.properties
.DS_Store
/build/
/app/build/
*.apk
*.ap_*
*.dex
*.class
*.log
*.hprof

# Fichiers volumineux et binaires
*.zip
*.jar
*.aar
*.tar.gz
*.7z
*.tgz
*.tar
*.gz
*.bin
*.exe
*.dll
*.so
*.dylib
*.pdb
*.tmp
*.swp
*.bak

# Dossiers générés par Gradle
/gradle-8.5-bin/
/gradle-8.5-bin.zip
/gradle-8.5-bin/
/gradle/
/gradle-*/

# Exclure les jars du dossier gradle-8.5-bin
/gradle-8.5-bin/**/*.jar

# Exclure les APKs générés
/app/release/*.apk

# Exclure les fichiers de configuration utilisateur
*.keystore
*.jks

# Exclure les fichiers de rapport
/build/reports/

# Exclure les fichiers de cache
/.gradle/
/.cxx/

# Exclure les fichiers de test générés
/app/build/intermediates/
/app/build/generated/

# Exclure les fichiers de configuration Android Studio
.cxx/

# Exclure les fichiers temporaires
*.tmp
*.temp

# Exclure les fichiers de sauvegarde
*~

# Exclure les fichiers de crash
crashlytics-build.properties

# Exclure les fichiers de signature
*.pem
*.crt
*.der

# Exclure les fichiers inutiles
Thumbs.db
Desktop.ini

# Protéger le dossier SOURCE (déjà ignoré)
/SOURCE/
